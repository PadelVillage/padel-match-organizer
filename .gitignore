.DS_Store

# File locali / dati reali da non caricare su GitHub
out.xlsx
out_prenotazioni.xlsx
Backup_Padel_*.json
*.xls
*.xlsx
*.csv

# Backup e versioni temporanee locali
*_backup.*
*_temp.*

# Cache locale creata dalla Supabase CLI
supabase/.temp/

# Da ora lo storico versioni vive su Git/GitHub, non in copie HTML locali.
# Eventuali snapshot manuali non devono entrare nel repository.
padel_match_organizer_v5_*.html

# Chiavi SSH di deploy Hetzner
pmo_deploy_key
pmo_deploy_key.pub

# Config locale editor/agent (non versionata)
.claude/

# Dipendenze npm locali (helper docx, non fanno parte del deploy index.html)
node_modules/
package.json
package-lock.json

# Lockfile generati da `deno check --node-modules-dir=auto` sulle edge function.
# Non versionati: il deploy non li usa (`supabase functions deploy --use-api` bundla
# server-side) e il gate typecheck e' differenziale, quindi base e head risolvono le
# dipendenze nello stesso momento e una versione nuova a monte non fa rumore.
# Sono 15 file: committati per sbaglio riempirebbero da soli il limite di 15 file
# per PR di guard-main-prs.yml.
supabase/functions/*/deno.lock

# Artefatti temporanei locali (debug/scratch)
_chromerr.txt
_doc.html
